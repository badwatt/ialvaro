---
import { getCollection } from "astro:content";

import Layout from "src/layouts/Layout.astro";
import { LoadingScreen } from "src/components/LoadingScreen";
import { ScrollProgress } from "src/components/ScrollProgress";
import { CursorGlow } from "src/components/CursorGlow";
import { Scrollup } from "src/components/Scrollup";
import { Marquee } from "src/components/Marquee";
import { Home } from "src/views/Home";
import { About } from "src/views/About";
import { Stats } from "src/views/Stats";
import { Skills } from "src/views/Skills";
import { Experience } from "src/views/Experience";
import { Portfolio } from "src/views/Portfolio";
import { Testimonials } from "src/views/Testimonials";
import { CV } from "src/views/CV";
import { Contact } from "src/views/Contact";

import skillsData from "src/data/skills.json";
import type { ExperienceEntry, PortfolioEntry, AboutEntry } from "src/utils/content";

const techStack = skillsData.map((s) => s.title);

const experienceDocs = await getCollection("experience");
const portfolioDocs = await getCollection("portfolio");
const aboutDocs = await getCollection("about");

const experienceData: ExperienceEntry[] = experienceDocs
  .map((e) => ({ ...e.data, description: e.body.trim() }))
  .sort((a, b) => Number(b.id) - Number(a.id));

const portfolioData: PortfolioEntry[] = portfolioDocs.map((e) => ({
  ...e.data,
  description: e.body.trim(),
}));

const aboutData: AboutEntry[] = aboutDocs.map((e) => ({
  id: e.data.id,
  bio: e.body.trim(),
}));
---

<Layout>
  <LoadingScreen client:load />
  <ScrollProgress client:load />
  <CursorGlow client:load />
  <Home client:load experienceData={experienceData} aboutData={aboutData} />
  <Marquee items={techStack} speed={35} />
  <About client:load aboutData={aboutData} />
  <Stats client:load experienceData={experienceData} portfolioData={portfolioData} />
  <Skills client:load />
  <Experience client:load experienceData={experienceData} />
  <Portfolio client:load portfolioData={portfolioData} />
  <Testimonials client:load />
  <CV client:load experienceData={experienceData} aboutData={aboutData} />
  <Contact client:load />
  <Scrollup client:load />
</Layout>
